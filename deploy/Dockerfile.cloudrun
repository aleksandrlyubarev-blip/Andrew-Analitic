# deploy/Dockerfile.cloudrun
#
# Cloud Run-tuned image for the Andrew bridge (FastAPI + LangGraph).
# Differs from the repo-root Dockerfile in three ways:
#   1) Listens on $PORT (Cloud Run injects this; defaults to 8080).
#   2) Single uvicorn worker — Cloud Run scales by adding instances.
#   3) Skips the Vue frontend stage; the Cloud Run service is API-only.
#      (Serve the SPA from Cloud Storage or Moltis if you need a UI.)

FROM python:3.12-slim

WORKDIR /app

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1 \
    PORT=8080 \
    LOG_FORMAT=json \
    BETA_AUTH_REQUIRED=true

RUN apt-get update \
    && apt-get install -y --no-install-recommends gcc libpq-dev curl \
    && rm -rf /var/lib/apt/lists/*

COPY requirements.txt .
RUN pip install -r requirements.txt \
 && pip install "psycopg[binary]>=3.2.0" "google-cloud-secret-manager>=2.20.0" \
                "gunicorn>=23.0.0"

COPY core/   core/
COPY bridge/ bridge/
COPY config/ config/

# Health probe — /healthz is the cheap process-alive check (no bridge init,
# no Moltis call). The richer /health endpoint exists for human curl, but
# would fail every probe whenever Moltis is unreachable (always on Cloud Run).
HEALTHCHECK --interval=30s --timeout=5s --start-period=20s --retries=3 \
    CMD curl -fsS "http://localhost:${PORT}/healthz" || exit 1

# gunicorn + uvicorn worker: handles slow LangGraph nodes without blocking the loop.
# --workers=1 because Cloud Run scales horizontally; --threads=8 is the in-process pool.
CMD exec gunicorn bridge.api:app \
    -k uvicorn.workers.UvicornWorker \
    --bind "0.0.0.0:${PORT}" \
    --workers 1 \
    --threads 8 \
    --timeout 3600 \
    --access-logfile - \
    --error-logfile -
