# Andrew Analytics — environment variables
# Copy to .env and fill in real values (never commit .env)

# ── API Keys ──────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Optional: E2B sandbox (safer code execution). Leave blank to use subprocess fallback.
# E2B_API_KEY=e2b_...

# ── Model overrides (optional — defaults shown) ───────────────────────────────
# MODEL_ORCHESTRATOR=anthropic/claude-sonnet-4-20250514
# MODEL_PYTHON=anthropic/claude-sonnet-4-20250514
# MODEL_ANALYTICS=gpt-4o-mini
# MODEL_SQL=gpt-4o-mini
# MODEL_REASONING_MATH=grok-4
# MODEL_ROMEO=gpt-4o-mini

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite (local dev):
DATABASE_URL=sqlite:///andrew.db

# PostgreSQL (production, used with: docker compose --profile production up):
# DATABASE_URL=postgresql://andrew:andrew2026@localhost:5432/andrew

# ── Moltis channel server ─────────────────────────────────────────────────────
MOLTIS_PASSWORD=andrew2026
# PG_PASSWORD=andrew2026    # only needed with --profile production

# ── Safety & quality knobs ────────────────────────────────────────────────────
# Maximum spend per query in USD (default: 1.00)
# ANDREW_MAX_COST=1.00

# Confidence threshold below which results are escalated to a human reviewer.
# The /analyze endpoint returns HTTP 202 + hitl_required=true when triggered.
# HITL_CONFIDENCE_THRESHOLD=0.35
