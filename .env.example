# Andrew Swarm — environment variables
# Copy to .env and fill in real values. Never commit .env.
#
#   cp .env.example .env
#   # then edit .env

# ── LLM API Keys (at least one required) ──────────────────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Optional: E2B sandbox (safer code execution). Leave blank to use subprocess fallback.
# E2B_API_KEY=e2b_...

# ── Model overrides (all optional — defaults shown) ───────────────────────────
# MODEL_ORCHESTRATOR=anthropic/claude-sonnet-4-20250514
# MODEL_PYTHON=anthropic/claude-sonnet-4-20250514
# MODEL_ANALYTICS=gpt-4o-mini
# MODEL_SQL=gpt-4o-mini
# MODEL_REASONING_MATH=grok-4
# MODEL_ROMEO=gpt-4o-mini
# MODEL_EDUCATOR=anthropic/claude-sonnet-4-20250514   # Romeo PhD agent

# ── Moltis runtime ────────────────────────────────────────────────────────────
MOLTIS_HOST=127.0.0.1
MOLTIS_PORT=13131
# Required — no default. Generate with: openssl rand -hex 32
MOLTIS_PASSWORD=

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite (local dev):
DATABASE_URL=sqlite:///andrew.db

# PostgreSQL (production — enable with: docker compose --profile production up):
# DATABASE_URL=postgresql://andrew:your-pg-password@localhost:5432/andrew
# PG_PASSWORD=                  # Required when using production profile. Generate with: openssl rand -hex 32

# ── Safety ────────────────────────────────────────────────────────────────────
ANDREW_MAX_COST=1.00            # Hard spend cap per query in USD
BRIDGE_PORT=8100                # Port the FastAPI bridge listens on
CORS_ALLOW_ORIGINS=https://romeoflexvision.com,https://www.romeoflexvision.com,http://localhost:5173,http://127.0.0.1:5173,http://localhost:4173,http://127.0.0.1:4173

# ── Human-in-the-loop (HITL) ──────────────────────────────────────────────────
# Confidence threshold below which results are escalated for human review.
# The /analyze endpoint returns HTTP 202 + hitl_required=true when triggered.
HITL_CONFIDENCE_THRESHOLD=0.35
# HITL_ENABLED=false
# HITL_WEBHOOK_URL=https://your-review-system/webhook
# HITL_TIMEOUT_SECONDS=120
# HITL_ON_TIMEOUT=approve       # "approve" or "reject" on webhook timeout

# ── Semantic routing (Sprint 5) ───────────────────────────────────────────────
# SEMANTIC_RELEVANCE_THRESHOLD=0.65
# EPISODIC_MAX_ENTRIES=20

# ── Memory consolidation + staleness sweep (Sprint 5) ─────────────────────────
# STALENESS_SWEEP_INTERVAL_S=86400

# ── Rate limiting (Sprint 6) — format: N requests / W seconds per IP ──────────
# RATE_LIMIT_ANALYZE=10/60
# RATE_LIMIT_EDUCATE=20/60
# RATE_LIMIT_WEBHOOK=30/60

# ── Andrew LCB Runner (competitive programming evaluation) ────────────────────
# ZhipuAI API key for GLM 5.1 (hard track — sparse MoE, ~40B active params)
# ZHIPUAI_API_KEY=your_zhipuai_key

# Model routing:
#   55% easy tasks → GPT-4o-mini ($0.15/$0.60 per 1M tokens)
#   45% hard tasks → GLM 5.1 via ZeroClaw/Moltis (MoE sweet spot: quality × cost)
# LCB_MODEL_EASY=gpt-4o-mini
# LCB_MODEL_HARD=zhipuai/glm-5.1    # or deepseek/deepseek-chat as fallback

# Candidate generation:
# LCB_EASY_CANDIDATES=2              # direct × 2 (GPT-4o-mini, cheap)
# LCB_HARD_CANDIDATES=4              # direct × 2 + plan_then_code + analogy
# LCB_MAX_REPAIR=3                   # repair iterations per candidate (Interleaved Thinking)
# LCB_PARALLEL_CANDIDATES=true       # generate candidates in parallel (SLIME-style async)
# LCB_SANDBOX_TIMEOUT=5              # seconds per test case execution

# Sandbox backend:
#   "subprocess" — local process execution (default, no dependencies)
#   "moltis"     — ZeroClaw/Moltis Docker sandbox (requires MOLTIS_* vars above)
# LCB_SANDBOX_BACKEND=subprocess

# Budget:
# LCB_MAX_COST=5.00                  # per-problem hard cap in USD
